{
  "name": "ohs-management-system-backend",
  "version": "1.0.0",
  "description": "Backend API for Occupational Health and Safety Management System",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "sequelize-cli db:migrate --config src/config/database-cli.js --migrations-path src/database/migrations",
    "db:seed": "node src/database/scripts/seedAllData.js",
    "db:seed:admin": "node src/database/scripts/seedAdminUser.js",
    "db:seed:master": "node src/database/scripts/seedMasterData.js",
    "db:seed:defaults": "node src/database/scripts/seedDefaultData.js",
    "db:seed:legacy": "sequelize-cli db:seed:all --config src/config/database-cli.js --seeders-path src/database/seeders",
    "lint": "eslint .",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.0.0"
  }
}
